; Engine configuration file.
; 角落垂钓 — 桌面角落挂机钓鱼挂件

config_version=5

[application]

config/name="角落垂钓"
run/main_scene="res://main.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")

[autoload]

Audio="*res://audio_manager.gd"

[display]

window/size/viewport_width=1040
window/size/viewport_height=720
window/size/borderless=false
window/size/transparent=false
window/size/always_on_top=false
window/size/no_focus=false
; 带框模式默认关闭逐像素透明（否则 Windows 分层窗运行时关不掉 → 实机仍透明+羽化）。
; 「沉浸模式」要透明挂件时再改回 true。
window/per_pixel_transparency/allowed=false
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
; 关逐显示器 DPI 感知：交给 Windows 统一按显示器缩放整窗位图。
; 否则在「主屏高缩放(如150%) + 副屏100%」混合多屏下，窗口挪到副屏时视口贴不齐
; 物理客户区，左/右/上会露 1px 窗口底色，像一条浅"描边"。代价：高缩放屏上水彩被
; 系统放大略柔（安静水彩风通常无感）。
window/dpi/allow_hidpi=false

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
