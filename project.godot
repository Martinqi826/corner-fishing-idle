; Engine configuration file.
; 角落垂钓 — 桌面角落挂机钓鱼挂件

config_version=5

[application]

config/name="角落垂钓"
run/main_scene="res://main.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")

[autoload]

Audio="*res://audio_manager.gd"

[display]

window/size/viewport_width=1040
window/size/viewport_height=720
window/size/borderless=false
window/size/transparent=false
window/size/always_on_top=false
window/size/no_focus=false
; 带框模式默认关闭逐像素透明（否则 Windows 分层窗运行时关不掉 → 实机仍透明+羽化）。
; 「沉浸模式」要透明挂件时再改回 true。
window/per_pixel_transparency/allowed=false
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
