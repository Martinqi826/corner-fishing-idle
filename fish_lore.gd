		"wiki": "翹嘴鮊"},
	"mandarin": {  # 鳜鱼
		"desc": "一身斑斓花纹的伏击者，藏在乱石缝里专吃活鱼，是江南名菜「松鼠桂鱼」的主角。",
		"fact": "鳜鱼天生只吃活鱼，从孵化起就拒食死饵，养殖时必须专门为它配活的饵料鱼。",
		"wiki": "鱖"},
	"largemouth": {  # 大口黑鲈
		"desc": "血盆大口的北美鲈，凶猛贪食，几乎吞得下半个身子大的猎物，是路亚之王。",
		"fact": "大口黑鲈嘴角能裂到眼睛后方，故名「大口」；它是全球路亚钓最热门的对象鱼，被引种到世界各地。",
		"wiki": "大口黑鱸"},
	"seabass": {  # 海鲈
		"desc": "近海与河口往来的银白掠食者，性子警觉，咬钩猛烈，是海钓里有名的「拉力王」。",
		"fact": "海鲈能在海水与淡水间自由穿行，常溯入河口追猎，因强劲的挣扎力被海钓爱好者奉为顶级游钓鱼。",
		"wiki": "花鱸"},
	"blackbream": {  # 黑鲷
		"desc": "通体青黑的礁区鲷鱼，牙口坚硬，专啃贝壳和甲壳，是矶钓人最爱的硬骨头。",
		"fact": "黑鲷雌雄同体、先雄后雌，年轻时多为雄性，长大后部分转为雌性；满口臼齿能咬碎贝壳。",
		"wiki": "黑鯛"},
	"hairtail": {  # 带鱼
		"desc": "银亮如刀的细长海鱼，立着身子在深水游动，满口尖牙，是冬季最鲜的海味。",
		"fact": "带鱼几乎垂直立在水中游泳，头朝上靠波浪状摆动升降；离水后银粉极易脱落，新鲜的才闪着完整的银光。",
		"wiki": "白帶魚"},
	"flounder": {  # 牙鲆
		"desc": "两眼挤到同一侧的扁平怪鱼，平贴沙底伪装，是海钓与餐桌都珍视的高级鱼。",
		"fact": "牙鲆幼鱼眼睛长在两侧、正常游泳，长大后一只眼逐渐「迁移」到另一侧，从此侧躺在海底生活。",
		"wiki": "牙鮃"},
	"conger": {  # 海鳗
		"desc": "藏在礁洞里的大海鳗，夜里探出身子捕食，一张利齿大口，咬钩力道十足。",
		"fact": "海鳗牙齿尖利、性情凶猛，白天蜷在岩洞和沉船里，夜晚出来掠食，是夜钓时分量惊人的对手。",
		"wiki": "海鰻"},
	"pufferfish": {  # 红鳍东方鲀
		"desc": "受惊就鼓成一个带刺圆球的河豚，模样憨态可掬，体内却藏着致命的毒。",
		"fact": "红鳍东方鲀的内脏与皮肤含剧毒河豚毒素，处理须持证厨师；它遇险时吸水鼓胀成刺球吓退天敌。",
		"wiki": "紅鰭東方魨"},
	"spinibarbus": {  # 光倒刺鲃
		"desc": "背鳍前藏着一根倒刺的溪河强鱼，体格健壮，在急流里冲刺有力。",
		"fact": "光倒刺鲃背鳍前方有一根平卧的倒刺，是它名字的由来；喜栖息于清澈多石的流水河段。",
		"wiki": "光倒刺鲃"},
	"mongolian_redfin": {  # 蒙古鲌
		"desc": "银白修长的湖中掠食者，与翘嘴是近亲，成群在中上层追猎小鱼。",
		"fact": "蒙古鲌（蒙古红鲌）是凶猛的肉食鲌类，常与翘嘴混群掠食，肉质细嫩，是北方大湖的经济鱼。",
		"wiki": "蒙古鮊"},
	"small_snakehead": {  # 月鳢
		"desc": "比黑鱼小巧的月鳢，身上缀着新月形花纹，藏在水草间伏击，护幼极凶。",
		"fact": "月鳢能用鳃上器呼吸空气，亲鱼会成群护送一团黑色的幼鱼苗在水面游动，谁靠近都猛冲驱赶。",
		"wiki": "月鱧"},
	"yellowfin_seabream": {  # 黄鳍鲷
		"desc": "鳍尖染着金黄的礁区鲷鱼，谨慎机敏，是南方矶钓人津津乐道的高手对决。",
		"fact": "黄鳍鲷各鳍泛黄而得名，对盐度宽容、能进河口，杂食且警觉，被矶钓爱好者视为斗智斗勇的对象鱼。",
		"wiki": "黃鰭鯛"},
	"crimson_snapper": {  # 红笛鲷
		"desc": "通体红艳的深礁笛鲷，成群巡游在礁缘外侧，是高价的食用海鱼。",
		"fact": "红笛鲷体色鲜红，是热带深礁区常见的笛鲷类，肉质紧实味美，为重要的经济与游钓鱼种。",
		"wiki": "笛鯛"},
	"spotted_scat": {  # 金钱鱼
		"desc": "圆扁身子缀满黑点的河口鱼，鳍棘带毒，常成群在红树林与码头边觅食。",
		"fact": "金钱鱼（金鼓鱼）背鳍硬棘有毒腺，被扎到剧痛；它能耐受从海水到淡水的大幅盐度变化。",
		"wiki": "金錢魚"},
	"octopus": {  # 章鱼
		"desc": "八条腕足在礁缝间灵活伸缩的软体猎手，能瞬间变色拟态，钻进任何缝隙藏身。",
		"fact": "章鱼有三颗心脏、蓝色血液，皮肤布满色素细胞能瞬间变色拟态，智力高到会用椰壳和石块搭建藏身所。",
		"wiki": "章魚"},
	"squid": {  # 鱿鱼
		"desc": "通体半透明、靠喷水疾退的快枪手，夜里被灯一照便成群涌来，是路亚「钓墨」的主角。",
		"fact": "鱿鱼靠漏斗喷水实现高速反向喷射推进，是游得最快的无脊椎动物之一，遇险还会喷墨遁走。",
		"wiki": "魷魚"},
	"cuttlefish": {  # 墨鱼
		"desc": "背着一块「海螵蛸」骨板的墨鱼，靠鳍波缓缓悬游，皮肤像电子屏一样流转花纹。",
		"fact": "墨鱼体内有一块多孔的石灰质内壳「海螵蛸」，靠调节其中气液比例控制浮沉，是天然的「潜水浮力舱」。",
		"wiki": "烏賊"},
	# —— 3 史诗 ——
	"snakehead": {  # 黑鱼
		"desc": "凶悍的伏击者，潜在水草里一动不动，等猎物游近才猛地暴起。",
		"fact": "乌鳢能用鳔辅助呼吸空气，离水后还能扭动身子，在湿地上「爬」去另一片水。",
		"wiki": "烏鱧"},
	"trout": {  # 虹鳟
		"desc": "侧身一道彩虹的冷水猎手，在清冽的溪流里逆水巡游，是飞蝇钓人魂牵梦萦的对象。",
		"fact": "虹鳟体侧有一道彩虹般的纵带而得名，对水温与溶氧极挑剔，是判断溪流是否洁净冷凉的活招牌。",
		"wiki": "虹鱒"},
	"pike": {  # 白斑狗鱼
		"desc": "潜在水草丛里的冷水伏击者，一身斑驳花纹，猎物游近便如箭离弦般暴起。",
		"fact": "白斑狗鱼满口尖牙朝内倒生，猎物一旦咬住便有去无回；它静止伏击、瞬间加速，是冷水里的「水下狗鱼」。",
		"wiki": "白斑狗魚"},
	"zander": {  # 梭鲈
		"desc": "梭形身子、眼睛泛着冷光的掠食鲈，喜在浑暗水里游猎，是欧洲钓友追捧的「玻璃眼」。",
		"fact": "梭鲈的眼睛有反光膜，在浑浊昏暗的水里视力极佳，因此专挑光线弱的时段和水域猎食。",
		"wiki": "梭鱸"},
	"longsnout": {  # 江团
		"desc": "吻部尖长的江中大鮠，夜里贴底觅食，肉质肥嫩无刺，是长江名贵的「江团」。",
		"fact": "江团（长吻鮠）无鳞、肉嫩少刺，鱼鳔肥厚可制成名贵的「鱼肚」，自古就是长江流域的席上珍馐。",
		"wiki": "長吻鮠"},
	"lenok": {  # 细鳞鱼
		"desc": "冷水溪流里的细鳞鲑，身上撒着细密小点，是北方山涧里灵巧又警觉的冷水鱼。",
		"fact": "细鳞鱼（细鳞鲑）鳞片极细密，只生活在水质清冷的山溪上游，对环境变化极敏感，是冷水生态的指标鱼。",
		"wiki": "細鱗鮭"},
	"yellowcheek": {  # 鳡鱼
		"desc": "细长如鳗、性情暴烈的湖中巨掠食者，疾游追猎，能把整群小鱼搅得四散逃命。",
		"fact": "鳡鱼游速极快、食量惊人，能长到一米多、几十斤重，是淡水里顶级的掠食者，对鱼塘破坏力极大。",
		"wiki": "鱤"},
	"eel": {  # 鳗鲡
		"desc": "夜里出没的滑溜长鱼，溯河而生、降海而产，一生要跨越千里大洋完成轮回。",
		"fact": "鳗鲡在淡水长大，成熟后洄游到数千公里外的深海产卵后死去；其完整的海中繁殖过程至今仍是未解之谜。",
		"wiki": "鰻鱺"},
	"seabream": {  # 真鲷
		"desc": "通体淡红、缀着蓝点的真鲷，是东亚文化里象征吉庆的「加吉鱼」，喜庆宴席的头牌。",
		"fact": "真鲷在日本被视为吉祥鱼，逢年过节必备；它寿命可达数十年，体色随光线与情绪在红粉之间变化。",
		"wiki": "真鯛"},
	"spanish_mackerel": {  # 马鲛鱼
		"desc": "流线身躯、游速极快的银亮海鱼，成群在近海追猎小鱼，咬钩猛烈如脱缰。",
		"fact": "马鲛鱼是高速洄游的掠食鱼，冲刺时速可达数十公里，肉质紧实，是东海冬季最受欢迎的时令鲜鱼。",
		"wiki": "馬鮫"},
	"pomfret": {  # 银鲳
		"desc": "身子扁圆泛着银光的银鲳，在中层成群缓游，肉厚刺少，是大众餐桌的常客。",
		"fact": "银鲳没有腹鳍、尾鳍呈深叉形，幼鱼常躲在水母触手下「搭便车」躲避天敌，长大后才独立成群。",
		"wiki": "銀鯧"},
	"grouper": {  # 石斑鱼
		"desc": "趴在礁石与深洞里的大块头石斑，一张大嘴产生的吸力，能瞬间把猎物连水吸进口中。",
		"fact": "石斑鱼多为先雌后雄，年轻时是雌性、长大后转为雄性；捕食时靠猛然张口的负压「吸食」整条小鱼。",
		"wiki": "石斑魚"},
	"yellowcroaker": {  # 大黄鱼
		"desc": "金黄通透的大黄鱼，曾是东海最丰饶的鱼汛，一网千斤，如今野生个体已珍稀难得。",
		"fact": "大黄鱼曾因过度捕捞资源近乎枯竭；它头骨内的耳石格外发达，旧时渔民循着鱼群的「咕咕」鸣声下网。",
		"wiki": "大黃魚"},
	"chinese_sucker": {  # 胭脂鱼
		"desc": "背鳍高耸如帆、身披红黑斑带的胭脂鱼，是长江里被称作「亚洲美人鱼」的国家级珍稀鱼。",
		"fact": "胭脂鱼幼鱼背鳍高扬、体色艳丽，被誉为「一帆风顺」；它是中国特有的珍稀鱼类，已列入保护名录。",
		"wiki": "胭脂魚"},
	"burbot": {  # 江鳕
		"desc": "唯一住在淡水的鳕鱼，下巴一根短须，专在冷水底层夜行，越冷越活跃。",
		"fact": "江鳕是鳕形目里唯一的纯淡水鱼，喜冷怕暖，常在冰封的隆冬产卵，是少数在严寒中繁殖的鱼类。",
		"wiki": "江鱈"},
	"manchurian_trout": {  # 花羔红点鲑
		"desc": "冷水清溪里的红点鲑，墨绿身子点缀着橙红斑点，是东北山涧里最艳丽的冷水鱼。",
		"fact": "花羔红点鲑体侧散布鲜艳的红点与白点，只生活在水质极佳的冷水溪流，对污染和升温毫无耐受力。",
		"wiki": "花羔紅點鮭"},
	"amur_catfish": {  # 怀头鲇
		"desc": "黑龙江里的大怀头鲇，宽扁大嘴贴底潜行，夜里能吞下相当大的猎物，是北方水域的巨型鲶。",
		"fact": "怀头鲇（六须鲇近亲）能长到一米多、几十斤重，是黑龙江流域最大的本土鲶类之一，夜行性的深水掠食者。",
		"wiki": "懷頭鯰"},
	"amberjack": {  # 高体鰤
		"desc": "体侧一道金线的高体鰤，成群在深水疾游掠食，强劲的冲刺是船钓人最过瘾的较量。",
		"fact": "高体鰤（章红鱼）是力气极大的洄游掠食鱼，被钩住后会拼命下潜，与垂钓者拔河般角力，深受船钓爱好者推崇。",
		"wiki": "高體鰤"},
	"cobia": {  # 军曹鱼
		"desc": "扁头长身、独来独往的军曹鱼，常跟在鲨鱼蝠鲼身后游弋，是深水里好奇又凶猛的大鱼。",
		"fact": "军曹鱼幼年酷似䲟鱼，常伴随大型鲨鱼、海龟和蝠鲼游动；它生长极快，是颇受欢迎的深海养殖与游钓鱼。",
		"wiki": "軍曹魚"},
	"barramundi": {  # 尖吻鲈
		"desc": "银亮大眼的尖吻鲈，在河口与近海间穿梭掠食，被钩住后凶猛跳跃，是热带海钓名鱼。",
		"fact": "尖吻鲈（盲槽）先雄后雌，多数年轻时是雄性、长大后变雌；它能在海水与淡水间自由迁徙繁殖。",
		"wiki": "尖吻鱸"},
	"miiuy_croaker": {  # 鮸鱼
		"desc": "近海泥沙底的大型石首鱼，鳔大肉厚，是渔家眼里「鱼肚」上品的来源。",
		"fact": "鮸鱼的鱼鳔肥大，干制成的「鮸鱼胶」是名贵的鱼肚补品，沿海有「千年鮸胶」之说，价值不菲。",
		"wiki": "鮸"},
	# —— 4 传说 ——
	"koi": {  # 锦鲤
		"desc": "鲤鱼里被人养出来的华服一族，红白相间游过，像水面铺开的一匹锦缎。",
		"fact": "锦鲤极长寿，一尾名为「花子」的活了 226 岁，年龄由鳞片上年轮般的纹路测定。",
		"wiki": "錦鯉"},
	"salmon": {  # 大马哈鱼
		"desc": "从大海溯流千里回到出生溪流的银亮洄游者，逆流跳跃、九死一生，只为完成生命的最后一程。",
		"fact": "大马哈鱼（大麻哈鱼）一生只繁殖一次，洄游回出生地产卵后力竭而亡；它们靠嗅觉记住故乡水的气味，跨越千里精准归巢。",
		"wiki": "大麻哈魚"},
	"sturgeon": {  # 施氏鲟
		"desc": "披着五行骨板的活化石，在江底缓缓游弋，吻下四根触须探着泥沙，活得比人还久。",
		"fact": "施氏鲟（史氏鲟）是亿万年几乎未变的古老鱼类，没有真正的骨骼、全靠软骨支撑，寿命可超过半个世纪。",
		"wiki": "史氏鱘"},
	"taimen": {  # 哲罗鲑
		"desc": "冷水河里的「淡水之虎」哲罗鲑，体长可逾两米，是溪河顶端令人胆寒的巨型掠食者。",
		"fact": "哲罗鲑是世界最大的鲑科鱼，能长到两米多长，会袭击游过水面的水鸟甚至小型兽类，是冷水河流的顶级猎手。",
		"wiki": "哲羅魚"},
	"wels_catfish": {  # 六须鲇
		"desc": "深潭里潜伏的六须巨鲇，入夜才离开洞穴出来觅食，一张大嘴能整个吞下成年的鱼。",
		"fact": "六须鲇（欧鲶）是欧洲最大的淡水鱼，记录个体近三米长；它们甚至学会冲上岸边伏击饮水的鸽子，再扭回水中。",
		"wiki": "六鬚鯰"},
	"tuna": {  # 金枪鱼
		"desc": "大洋里的远航者，永不停歇地游动，是海里数一数二的速度健将。",
		"fact": "金枪鱼是少数「温血」的鱼，体温能高于海水，肌肉更有力，冲刺时速可达 70 公里。",
		"wiki": "鮪"},
	"giant_grouper": {  # 龙趸石斑
		"desc": "礁区里最庞大的龙趸石斑，张口的吸力能把整条小鲨连水吞下，是深洞里的庞然霸主。",
		"fact": "龙趸（鞍带石斑鱼）是体型最大的礁栖硬骨鱼，可长到近三米、数百公斤，大到能一口吞下小型鲨鱼。",
		"wiki": "鞍帶石斑魚"},
	"mahseer": {  # 结鱼
		"desc": "披着大块金鳞的结鱼，在湍急的山河里逆流搏击，是亚洲溪河运动钓的传奇巨物。",
		"fact": "结鱼（金吉罗鱼）大鳞如金币、力大无穷，被英属时期的钓鱼者誉为「印度的鲑鱼」，是亚洲淡水运动钓的圣杯。",
		"wiki": "結魚"},
	"marbled_eel": {  # 花鳗鲡
		"desc": "身披云石花纹的大花鳗，夜里在深潭与河口间潜行，能长到一人多长，是溪河里的暗夜巨鳗。",
		"fact": "花鳗鲡同样要降海产卵，却能长到两米、几十斤，是世界最大的淡水鳗之一；在台湾被列为保护的珍稀鱼类。",
		"wiki": "花鰻鱺"},
	"marlin": {  # 马林鱼
		"desc": "举着一柄长枪般上颌的大洋猛士，以惊人速度劈浪疾驰，是远洋运动钓的至高荣耀。",
		"fact": "马林鱼（旗鱼科）的上颌延长成尖锐的「长矛」，冲刺时速可达上百公里，常用长喙击晕鱼群再从容捕食。",
		"wiki": "馬林魚"},
	"giant_trevally": {  # 浪人鲹
		"desc": "银亮如盾的浪人鲹，成群在礁缘外冲撞鱼群，凶猛霸道，是岸抛与路亚钓的终极对手。",
		"fact": "浪人鲹（GT）是凶猛的礁区顶级掠食者，甚至能跃出水面拍击、捕食低飞掠过海面的海鸟。",
		"wiki": "浪人鰺"},
	"mahimahi": {  # 鲯鳅
		"desc": "通体金蓝、额头高耸的鲯鳅，在大洋表层风驰电掣，被钓起时体色如焰火般闪烁变幻。",
		"fact": "鲯鳅（鬼头刀）是生长最快的鱼类之一，几个月就能长到一米；离水时体色在金、蓝、绿间剧烈流转，几分钟后归于暗淡。",
		"wiki": "鯕鰍"},
	"swordfish": {  # 剑鱼
		"desc": "顶着一柄扁平长剑的深海独行客，能潜入幽暗深水又跃上表层，是夜钓远洋的传奇巨物。",
		"fact": "剑鱼上颌如一柄宽扁长剑，眼部有特殊的「加热器官」给眼睛和大脑保温，使它在冰冷深水里仍保持敏锐视力。",
		"wiki": "劍魚"},
	"wahoo": {  # 刺鲅
		"desc": "细长如标枪的刺鲅，是大洋里游速数一数二的快鱼，咬钩瞬间能把卷线器拉得尖啸。",
		"fact": "刺鲅（沙氏刺鲅）短距离冲刺时速可超过七十公里，是海洋里最快的鱼类之一，满口剃刀般的利齿。",
		"wiki": "刺鮁"},
	# —— 5 神话 ——
	"chinese_sturgeon": {  # 中华鲟
		"desc": "长江里游了一亿四千万年的活化石，溯流千里只为回到故乡产卵，是当之无愧的「水中大熊猫」。",
		"fact": "中华鲟在海里长大、洄游入长江产卵，单次可产数十万枚卵；它已存在逾亿年，是国家一级保护动物，野生种群极度濒危。",
		"wiki": "中華鱘"},
	"kaluga": {  # 达氏鳇
		"desc": "黑龙江里的达氏鳇，能长到一吨重、活过半个世纪，是淡水里体型最巨的鱼之一。",
		"fact": "达氏鳇是世界最大的淡水鱼之一，记录个体超过一吨、长达五米多，寿命可逾五十年；如今因过度捕捞已极度濒危。",
		"wiki": "達氏鰉"},
	"sailfish": {  # 旗鱼
		"desc": "扬着一面巨帆般背鳍的旗鱼，是海洋里游得最快的鱼，疾驰时帆收进沟槽，破浪如离弦之箭。",
		"fact": "旗鱼是公认游速最快的海洋鱼类，冲刺时速可达上百公里；它高大的背帆能立起来围拢、驱赶鱼群，便于群体捕食。",
		"wiki": "旗魚"},
	"paddlefish": {  # 白鲟
		"desc": "吻部伸出一柄长桨的白鲟，曾是长江里的「水中老虎」，遗憾的是已被宣告灭绝。",
		"fact": "长江白鲟是中国特有的古老巨鱼，可长到数米；2019 年被科学界正式宣告灭绝，成为长江生态之殇的沉痛注脚。",
		"wiki": "白鱘"},
	"coelacanth": {  # 矛尾鱼
		"desc": "本以为和恐龙一同绝灭、却在深海被重新发现的矛尾鱼，是震惊世界的「活化石之王」。",
		"fact": "矛尾鱼曾被认为在六千五百万年前就已灭绝，1938 年却在南非海域被活捉；它长着肉质的叶状鳍，是陆生脊椎动物的远古近亲。",
		"wiki": "矛尾魚"},
	"oarfish": {  # 皇带鱼
		"desc": "深海里银亮如带、头顶红鬃的皇带鱼，能长到十几米，是「龙宫使者」「地震鱼」传说的原型。",
		"fact": "皇带鱼是世界最长的硬骨鱼，记录可达十一米；它极少现身，偶尔搁浅便被民间附会成地震前兆，故称「地震鱼」。",
		"wiki": "皇帶魚"},
	"whale_shark": {  # 鲸鲨
		"desc": "海洋里最大的鱼，温和地张着巨口滤食浮游生物，身披星点，像一片缓缓游动的星空。",
		"fact": "鲸鲨是现存最大的鱼类，可长到十八米以上，却只滤食浮游生物和小鱼；每条身上的斑点排列独一无二，如同指纹。",
		"wiki": "鯨鯊"},
	# —— 0 普通 ——
	"amur_minnow": {  # 柳根鱼
		"desc": "北方山溪里的耐寒小鱼，雪水化开时最先成群活跃，钓上来还带着冰凉。",
		"fact": "柳根鱼极耐低温，是黑龙江流域开江后最早咬钩的鱼之一，冰钓人管它叫「报春鱼」。",
		"wiki": "拉氏鱥"},
	"hillstream_loach": {  # 平鳍鳅
		"desc": "扁平贴石的小鳅，鳍展开像吸盘，牢牢扒在急流的石头上一动不动。",
		"fact": "平鳍鳅的胸腹鳍特化成吸附器官，能在湍急的山涧里贴着石面逆流而行，绝不被冲走。",
		"wiki": "平鰭鰍"},
	"plateau_loach": {  # 高原鳅
		"desc": "高原冷水里的小硬汉，身子粗短鳞片细密，在缺氧的雪水里照样活蹦乱跳。",
		"fact": "高原鳅适应了青藏高原的低温缺氧，能在海拔五千米以上的冷水里生存，是分布最高的鱼类之一。",
		"wiki": "高原鰍"},
	# —— 1 优良 ——
	"largescale_shoveljaw": {  # 多鳞白甲鱼
		"desc": "山涧急流里刮石觅食的中鱼，下颌像把铲子，专啃石头上的青苔。",
		"fact": "多鳞白甲鱼（多鳞铲颌鱼）下颌前缘有锐利角质鞘，像铲子一样刮取石面藻类，是清流河段的指标鱼。",
		"wiki": "多鱗白甲魚"},
	"taiwan_shoveljaw": {  # 台湾铲颌鱼
		"desc": "宝岛山溪里的「苦花」，逆流贴石刮食，鳞片在清水里闪着银光，是溪钓珍味。",
		"fact": "台湾铲颌鱼俗称「苦花」，因腹内苦胆与刮食的藻类带微苦得名，是台湾清澈溪流的代表性原生鱼。",
		"wiki": "臺灣鏟頷魚"},
	# —— 2 稀有 ——
	"rock_carp": {  # 岩原鲤
		"desc": "栖在山涧深潭乱石间的冷水鲤，体色暗沉，肉质细嫩，是西南名贵的「水中人参」。",
		"fact": "岩原鲤生长极慢、对水质要求高，野生资源稀少，因肉质鲜美在西南地区被视为珍贵的食用鱼。",
		"wiki": "岩原鯉"},
	"schizothorax": {  # 裂腹鱼
		"desc": "高原冷水里的银亮裂腹鱼，腹部一道裂缝似的纵沟，在雪水溪流里逆流而上。",
		"fact": "裂腹鱼因肛门与臀鳍两侧有特化的「裂腹」鳞片得名；它是青藏高原冷水水系的代表鱼类，鱼卵带毒不可食。",
		"wiki": "裂腹魚"},
	# —— 3 史诗 ——
	"torrent_catfish": {  # 石爬鮡
		"desc": "贴在山涧急流石底的小石爬鮡，胸腹愣是吸成一片，激流冲不走、夜里才出来觅食。",
		"fact": "石爬鮡（鮡科）的胸腹部皮肤特化能吸附岩石，在湍急冷冽的高山溪流底层逆流爬行，是清流的指标鱼。",
		"wiki": "鮡"},
	"grayling": {  # 北极茴鱼
		"desc": "背鳍高大如帆、泛着虹彩的北极茴鱼，在冷水清流里成群迎流，是飞蝇钓的梦幻对象。",
		"fact": "北极茴鱼有一面又高又大、闪着紫红虹彩的背鳍，是冷水溪流里最华丽的鲑科鱼，身上还带着淡淡的麝香气味。",
		"wiki": "茴魚"},
	# —— 5 神话 ——
	"sichuan_taimen": {  # 川陕哲罗鲑
		"desc": "秦岭山溪里的川陕哲罗鲑，冷水中的本土巨鲑，如今已濒临灭绝，难得一见。",
		"fact": "川陕哲罗鲑是中国特有的大型冷水鲑，仅存于秦岭一带的清冷溪流，因栖息地破坏与捕捞已极度濒危，是国家重点保护物种。",
		"wiki": "川陝哲羅鮭"},
	# —— 0 普通 ——
	"lanternfish": {  # 灯笼鱼
		"desc": "深海中层最不起眼的小鱼，身侧点着一排幽幽蓝光，成群游过像撒了一把星子。",
		"fact": "灯笼鱼是地球上数量最多的脊椎动物之一，每晚集体上浮觅食、天亮下潜，是海洋最大规模的昼夜迁徙。",
		"wiki": "燈籠魚"},
	"bristlemouth": {  # 钻光鱼
		"desc": "深渊里几乎透明的小细鱼，嘴边一圈细密的针牙，是黑暗中沉默的微光。",
		"fact": "钻光鱼被认为是地球上数量最多的脊椎动物，总数以千万亿计，却因深居海底鲜为人知。",
		"wiki": "鑽光魚"},
	# —— 1 优良 ——
	"hatchetfish": {  # 银斧鱼
		"desc": "侧看像把小银斧的深海怪鱼，腹部点着一排发光器，在幽暗中若隐若现。",
		"fact": "银斧鱼腹部的发光器能模拟微弱的下行天光，从下方看正好「隐形」，骗过潜伏在更深处的掠食者。",
		"wiki": "褶胸魚"},
	"rattail": {  # 鼠尾鳕
		"desc": "拖着一条细长尾巴的深海鳕，在海底慢慢游荡，用大头探嗅泥里的食物。",
		"fact": "鼠尾鳕是深海最常见的鱼类之一，尾部细长如鼠尾，多数能用鱼鳔发声，在黑暗中彼此联络。",
		"wiki": "鼠尾鱈"},
	# —— 2 稀有 ——
	"dragonfish": {  # 巨口鱼
		"desc": "深渊里嘴大牙长的小恶魔，下巴垂着一根发光的「钓须」，在永夜里诱捕路过的小鱼。",
		"fact": "巨口鱼颏下有一根带发光器的须，用来引诱猎物；有的种类能发出红光，而猎物看不见红光，等于开了「夜视外挂」。",
		"wiki": "巨口魚"},
	"lancetfish": {  # 帆蜥鱼
		"desc": "背鳍像一面高高竖起的帆，身子细长如刀，是深海里贪婪到会自相残杀的怪客。",
		"fact": "帆蜥鱼胃里常发现同类残骸，是出了名的「来者不拒」；它代谢慢、肌肉含水多，几乎不被人类食用。",
		"wiki": "帆蜥魚"},
	# —— 3 史诗 ——
	"anglerfish": {  # 鮟鱇
		"desc": "深渊里头顶一盏「灯笼」的丑怪鱼，在永夜中点亮诱饵，等小鱼凑近便一口吞下。",
		"fact": "深海鮟鱇头顶的发光「钓竿」靠共生细菌发光；某些种类的雄鱼会咬住雌鱼融为一体，终生寄生只为繁殖。",
		"wiki": "鮟鱇"},
	"escolar": {  # 异鳞蛇鲭
		"desc": "深水里油亮肥厚的蛇鲭，肉如肥牛般丰腴，却因含蜡油不宜多吃，是争议十足的「深海肥鱼」。",
		"fact": "异鳞蛇鲭肌肉富含人体无法消化的蜡酯，吃多了会引起肠胃不适，许多地区因此对它的销售有所限制。",
		"wiki": "異鱗蛇鯖"},
	# —— 4 传说 ——
	"opah": {  # 月鱼
		"desc": "圆盘般的银红大鱼，鳍如红绸，独自巡游在深暗洋层，是少数浑身暖洋洋的「温血鱼」。",
		"fact": "月鱼是已知第一种真正的全身温血鱼，靠胸鳍肌肉持续产热、用特殊血管保温，让它在冰冷深海里依旧活跃敏捷。",
		"wiki": "月魚"},
	# —— 5 神话 ——
	"giant_squid": {  # 大王乌贼
		"desc": "深渊里的大王乌贼，眼大如盘、长腕缠卷，是无数海怪传说背后那条真实的深海巨兽。",
		"fact": "大王乌贼的眼睛是动物界最大的，直径可达篮球大小，用来在漆黑深海捕捉抹香鲸游动搅起的微光；它与抹香鲸的搏斗是深海最壮烈的对决。",
		"wiki": "大王烏賊"},
	# —— 0 普通 ——
	"clownfish": {  # 小丑鱼
		"desc": "橙白相间的小胖墩，钻进海葵的触手里安家，探头探脑地打量来客。",
		"fact": "小丑鱼对海葵毒刺免疫，靠体表黏液躲在毒触手间；它们天生都是雄性，群体首领死后会有雄鱼变成雌鱼。",
		"wiki": "海葵魚"},
	"damselfish": {  # 雀鲷
		"desc": "礁石间最常见的彩色小点，护着自己那一小片珊瑚，连大鱼路过都敢去顶撞。",
		"fact": "雀鲷是出了名的「珊瑚农夫」，会精心照料自己领地里的藻类，赶走任何来啃食的入侵者。",
		"wiki": "雀鯛"},
	"cardinalfish": {  # 天竺鲷
		"desc": "白天躲在礁缝里、夜里才出来活动的小红鱼，一双大眼专为暗光而生。",
		"fact": "天竺鲷是「口孵」鱼，雄鱼把受精卵含在嘴里孵化，期间几乎不进食，直到小鱼游出。",
		"wiki": "天竺鯛"},
	"chromis": {  # 蓝绿光鳃鱼
		"desc": "成群悬在珊瑚枝头的一抹流动蓝绿，光线一变就闪烁出不同的颜色。",
		"fact": "蓝绿光鳃鱼的体色会随光线和情绪变化，受惊时整群瞬间躲进珊瑚缝隙，像被吸进去一样。",
		"wiki": "光鰓魚"},
	"blenny": {  # 鳚鱼
		"desc": "趴在礁石上的小滑头，眼睛上方支着两根羽状触须，一受惊就钻进小洞只露个头。",
		"fact": "鳚鱼常年赖在空贝壳或岩缝里当家，护巢极凶，连手指伸近都会冲上来虚张声势地咬一口。",
		"wiki": "鳚"},
	"firefish": {  # 红火箭
		"desc": "拖着一面火红长鳍贴底悬停，浮在洞口随时准备一闪而入，是礁区里的小焰苗。",
		"fact": "红火箭（丝鳍鳚）极度胆小，总在自掘的沙洞口悬停，第一背鳍像旗杆般竖立，稍有风吹草动便倒射进洞。",
		"wiki": "絲鰭鸚天竺鯛"},
	# —— 1 优良 ——
	"butterflyfish": {  # 蝴蝶鱼
		"desc": "扁圆身子描着艳丽花纹的礁区舞者，成对穿梭在珊瑚枝间，是水族里最受宠的小美人。",
		"fact": "蝴蝶鱼常终生成对生活，许多种类尾部或体侧有一个「假眼」斑点，迷惑捕食者去攻击错误的方向。",
		"wiki": "蝴蝶魚"},
	"surgeonfish": {  # 刺尾鱼
		"desc": "尾柄两侧藏着锋利小刀的素食者，成群刮食礁石上的藻类，惹急了会甩尾割人。",
		"fact": "刺尾鱼尾柄两侧长着像手术刀一样锋利的硬棘，平时收起，受威胁时弹出横扫，因此得名。",
		"wiki": "刺尾魚"},
	"anthias": {  # 金拟花鮨
		"desc": "成千上万悬在礁缘的橙红小鱼，随波起伏像一片流动的火焰。",
		"fact": "金拟花鮨群体里只有少数雄鱼，雄鱼死后会有最强势的雌鱼在几天内变性顶上，维持种群的繁殖结构。",
		"wiki": "擬花鮨"},
	"wrasse": {  # 隆头鱼
		"desc": "色彩斑斓、嘴尖牙利的礁区游民，白天四处翻找小虫，夜里钻进沙里裹着黏液睡觉。",
		"fact": "许多隆头鱼晚上会潜入沙底、或分泌一层黏液「睡袋」把自己包住，借此遮蔽气味躲过夜行掠食者。",
		"wiki": "隆頭魚"},
	"foxface": {  # 狐狸鱼
		"desc": "尖嘴长脸像只小狐狸的礁鱼，鳍棘带毒，慢悠悠啃食藻类，受惊时体色瞬间变花。",
		"fact": "狐狸鱼（蓝带臭肚鱼）的背鳍和臀鳍棘带毒腺，受惊或睡觉时会显出杂乱的斑驳保护色。",
		"wiki": "臭肚魚"},
	"hawkfish": {  # 鹰斑鲷
		"desc": "爱停在珊瑚枝头「站岗」的小鱼，用粗壮的胸鳍撑住身子，居高临下盯着猎物。",
		"fact": "鹰斑鲷没有鱼鳔，靠加粗的胸鳍条架在珊瑚上歇息，像鹰栖枝头一样守望，发现小鱼便俯冲扑食。",
		"wiki": "鷹斑鯛"},
	# —— 2 稀有 ——
	"angelfish": {  # 神仙鱼
		"desc": "高耸侧扁、披着华丽条纹的礁区贵族，慢悠悠在珊瑚间巡游，是海水缸里的明星。",
		"fact": "海水神仙鱼幼鱼和成鱼花纹常截然不同，差异大到曾被误认成两个物种；许多种类幼年还会替大鱼「清洁」体表。",
		"wiki": "神仙魚"},
	"parrotfish": {  # 鹦哥鱼
		"desc": "嘴像鹦鹉喙的彩色礁鱼，「咔哧咔哧」啃着珊瑚，啃下的碎屑最后变成了海滩的白沙。",
		"fact": "鹦哥鱼用喙状齿啃食珊瑚上的藻类，排出的珊瑚碎屑就是热带白沙滩的主要来源——一条大鱼一年能造上百公斤沙。",
		"wiki": "鸚哥魚"},
	"triggerfish": {  # 鳞鲀
		"desc": "背鳍能像扳机一样卡住的礁鱼，钻进石缝就竖棘卡死，谁也别想把它拽出来。",
		"fact": "鳞鲀的第一背鳍棘能被第二根小棘「锁定」竖直，钻进洞里一卡就纹丝不动；护巢时连潜水员都敢驱赶。",
		"wiki": "鱗魨"},
	"lionfish": {  # 狮子鱼
		"desc": "张开满身羽状毒鳍、像狮鬃般招摇的礁区杀手，慢悠悠地把小鱼逼进角落一口吞下。",
		"fact": "狮子鱼背鳍布满含毒棘刺，被刺剧痛；它被带入大西洋后毫无天敌、疯狂繁殖，成了臭名昭著的入侵物种。",
		"wiki": "蓑鲉"},
	"moray": {  # 裸胸鳝
		"desc": "藏在礁洞里只露出大头的裸胸鳝，一张一合地呼吸露出利齿，夜里才出洞捕猎。",
		"fact": "裸胸鳝（海鳝）咽喉里还藏着第二副「咽颌」，能伸出来把咬住的猎物拖进喉咙——和异形电影里的设定如出一辙。",
		"wiki": "裸胸鱔"},
	"boxfish": {  # 箱鲀
		"desc": "整个身子裹在硬骨甲盒里的方块鱼，只能小幅摆鳍慢慢挪动，呆萌得不像话。",
		"fact": "箱鲀的身体被融合的骨板包成一只硬盒，受惊时还能从皮肤释放毒素；外形虽笨拙，水动力学却出奇地高效。",
		"wiki": "箱魨"},
	"spotted_puffer": {  # 斑点叉鼻鲀
		"desc": "缀满斑点的小河豚，鼓起来圆滚滚像颗带刺的球，眼睛会独立转动打量四周。",
		"fact": "斑点叉鼻鲀靠吞水或吞气把身体胀大数倍吓退天敌，皮肤和内脏同样含有河豚毒素。",
		"wiki": "叉鼻魨"},
	# —— 3 史诗 ——
	"coral_grouper": {  # 东星斑
		"desc": "通体艳红、缀满蓝点的东星斑，栖在深礁洞穴里，是海鲜酒楼里身价不菲的清蒸名鱼。",
		"fact": "东星斑（豹纹鳃棘鲈）狩猎时会与裸胸鳝「合作」——摆头示意鳝钻进石缝把猎物逼出，是少见的跨物种联手捕食。",
		"wiki": "豹紋鰓棘鱸"},
	"bohar_snapper": {  # 千年笛鲷
		"desc": "深礁外缘的千年笛鲷，体格粗壮、牙口凶悍，是热带大礁区里令人生畏的掠食笛鲷。",
		"fact": "千年笛鲷（红鳍笛鲷）个大牙利，是热带礁区凶猛的掠食者；大个体常累积「雪卡毒素」，食用有中毒风险。",
		"wiki": "笛鯛"},
	"emperor_fish": {  # 龙占鱼
		"desc": "嘴部肥厚、体色随情绪变幻的龙占鱼，在礁沙交界处拱食贝类，是印太海域的常见名鱼。",
		"fact": "龙占鱼（裸颊鲷）满口臼齿专门压碎贝壳和甲壳；它能根据情绪和环境迅速改变体色与斑纹深浅。",
		"wiki": "裸頰鯛"},
	"unicornfish": {  # 独角倒吊
		"desc": "额头顶着一只「角」的刺尾鱼，成群在礁缘逆流啃食藻类，尾柄两侧暗藏利刃。",
		"fact": "独角倒吊（颊吻鼻鱼）成年后额头会长出一只角状突起，故名「独角」；尾柄两侧有锋利骨板，挥尾即是武器。",
		"wiki": "鼻魚"},
	# —— 4 传说 ——
	"bumphead_parrot": {  # 隆头鹦哥
		"desc": "额头隆起一个大包的巨型鹦哥，成群「咔咔」啃食活珊瑚，是礁区里庞大而温和的造沙巨匠。",
		"fact": "隆头鹦哥是最大的鹦哥鱼，一条成年大鱼一年能啃食并排出数吨珊瑚碎屑——热带白沙滩的相当一部分都出自它「口」。",
		"wiki": "隆頭鸚哥魚"},
	"dogtooth_tuna": {  # 狗牙金枪
		"desc": "满口犬牙的礁区金枪，潜伏在深礁陡坡外伏击，强劲的下潜冲刺让钓手叫苦不迭。",
		"fact": "狗牙金枪（齿鰆）有一口锥状犬齿，是礁区凶猛的掠食者；被钩住后会拼命垂直下潜，常把钓线扯断在礁石上。",
		"wiki": "齒鰆"},
	# —— 5 神话 ——
	"napoleon_wrasse": {  # 苏眉
		"desc": "额头隆起如拿破仑帽的巨型隆头鱼，色彩斑斓、神态从容，是珊瑚礁里温和的「礁石之王」。",
		"fact": "苏眉（波纹唇鱼）能长到两米、活过三十年，先雌后雄；因肉味珍贵被滥捕，如今已是濒危的国际保护物种。",
		"wiki": "波紋唇魚"},
	"manta_ray": {  # 蝠鲼
		"desc": "舒展着巨翼般胸鳍、在海中「飞翔」的蝠鲼，温和地滤食浮游生物，是大洋里最优雅的庞然身影。",
		"fact": "蝠鲼翼展可达七米，是脑容量比例最大的鱼类之一，能认出镜中的自己；它们温和无害，却因鳃板被滥捕而日渐稀少。",
		"wiki": "蝠鱝"},
	# —— 0 普通 ——
	"mudskipper": {  # 弹涂鱼
		"desc": "退潮的泥滩上蹦跳的小怪客，用胸鳍「走路」，鼓着大眼东张西望。",
		"fact": "弹涂鱼能离水生活数小时，靠皮肤和口腔黏膜呼吸，用胸鳍在泥滩上爬行甚至跳跃求偶。",
		"wiki": "彈塗魚"},
	"glassfish": {  # 玻璃鱼
		"desc": "通体透明得能看见骨架和内脏，在汽水里成群游动，像一片会动的碎玻璃。",
		"fact": "玻璃鱼的身体几乎完全透明，肌肉缺乏色素，连脊椎和鳔都清晰可见。",
		"wiki": "玻璃魚"},
	"silverside": {  # 银汉鱼
		"desc": "身侧一道亮银带子，贴着水面成群巡游，是河口里最闪眼的小银鱼。",
		"fact": "银汉鱼常在黎明大规模聚集到岸边产卵，潮水退去时把卵留在湿沙里，靠下一波潮水孵化。",
		"wiki": "銀漢魚"},
	# —— 1 优良 ——
	"archerfish": {  # 射水鱼
		"desc": "河口红树林里的神射手，盯着枝头的虫子，一口水柱「啪」地把它打落水面。",
		"fact": "射水鱼能从口中精准喷出水柱，击落两米外停在枝叶上的昆虫，还会自动修正水面折射造成的视觉偏差。",
		"wiki": "射水魚"},
	"threadfin": {  # 四指马鲅
		"desc": "胸鳍下垂着几根游离长丝，在浑浊河口靠它摸索觅食，是潮间带的常见食用鱼。",
		"fact": "四指马鲅胸鳍下方有几根分离的丝状鳍条，像伸出的手指，能在浑水中触探底泥里的小鱼小虾。",
		"wiki": "馬鮁"},
	"marble_sleeper": {  # 笋壳鱼
		"desc": "趴在汽水底层伪装成石头的大头鱼，守着洞口伏击猎物，是华南名贵的塘鳢。",
		"fact": "笋壳鱼（云斑尖塘鳢）习惯静伏底层、代谢缓慢、耐运输，是华南与东南亚高价的食用塘鳢类。",
		"wiki": "尖塘鱧"},
	"silverbiddy": {  # 碟仔鱼
		"desc": "嘴能伸缩的小银碟鱼，在河口沙底成群拱食，一受惊整群闪成一片银光。",
		"fact": "碟仔鱼（钻嘴鱼）的口部能向前伸出成管状，伸进沙泥里吸食底栖小生物。",
		"wiki": "鑽嘴魚"},
	# —— 2 稀有 ——
	"mangrove_snapper": {  # 紫红笛鲷
		"desc": "红树根丛里巡游的紫红笛鲷，机警凶猛，专伏在盘根错节的水下守候猎物。",
		"fact": "紫红笛鲷常聚集在红树林与礁石的复杂结构里，幼鱼把这里当育婴房，红树林正是众多海鱼的天然苗圃。",
		"wiki": "笛鯛"},
	"fingermark": {  # 画眉笛鲷
		"desc": "鳃盖上一抹墨斑像被画了眉的笛鲷，栖在河口与近礁，是热带海钓的常见好货。",
		"fact": "画眉笛鲷（勒氏笛鲷）鳃盖后上方常有一个深色斑点，像描了一笔眉，是它在笛鲷家族里的辨识标志。",
		"wiki": "笛鯛"},
	"milkfish": {  # 虱目鱼
		"desc": "通体银白、游速飞快的河口大鱼，跳跃力惊人，被钩住后常一连串跃出水面。",
		"fact": "虱目鱼是东南亚重要的养殖鱼，鱼苗曾全靠在河口捞捕；它能耐受宽广的盐度，从海水到淡水都活得好。",
		"wiki": "虱目魚"},
	"tigerperch": {  # 花身鸡鱼
		"desc": "身上几道虎纹的河口小猛鱼，受惊时鱼鳔会「呱呱」作响，成群在桥桩边觅食。",
		"fact": "花身鸡鱼（花身鯻）能用鱼鳔肌肉发出「咕咕」「呱呱」的叫声，离水时尤其明显，故俗称「鸡鱼」。",
		"wiki": "花身鯻"},
	# —— 3 史诗 ——
	"king_threadfin": {  # 大午
		"desc": "河口浑水里的大型马鲅，胸鳍垂着长长的「手指」探路，是热带泥滩里凶猛的大掠食者。",
		"fact": "大午（多指马鲅）胸鳍下有多达数根游离的丝状鳍条，在浑浊的河口泥水中靠它感知和搜寻底栖猎物。",
		"wiki": "馬鮁"},
	"tarpon": {  # 大海鲢
		"desc": "披着大块银鳞的大海鲢，被钩住后会一连串腾空翻跃，是热带海钓中最具观赏性的「银王」。",
		"fact": "大海鲢能吞咽空气、用鳔辅助呼吸，在缺氧水里也能活；它中钩后剧烈跳跃甩钩，是游钓界传奇般的对象鱼。",
		"wiki": "大海鰱"},
	"estuary_stingray": {  # 赤魟
		"desc": "趴在河口泥底的赤魟，半埋进沙里只露双眼，尾上一根毒刺是它的护身武器。",
		"fact": "赤魟尾部有带倒钩的毒棘，受踩踏时反甩刺入，伤口剧痛；它平时埋伏沙泥中，靠电感受器探测猎物。",
		"wiki": "赤魟"},
	# —— 4 传说 ——
	"bull_shark": {  # 公牛鲨
		"desc": "能溯入淡水河的公牛鲨，性情暴烈、来去无踪，常出没在浑浊的河口与红树林深处。",
		"fact": "公牛鲨是少数能在淡水中长期生活的鲨鱼，曾溯入江河上千公里；它对盐度的超强适应力让河口成了它的猎场。",
		"wiki": "公牛真鯊"},
	"giant_threadfin": {  # 巨马鲅
		"desc": "河口浑水里的巨型马鲅，胸鳍长丝探着泥底，体格魁梧，是热带泥滩里令人忌惮的大掠食者。",
		"fact": "巨马鲅（四指马鲅大个体）能长到一米多，胸鳍游离的丝状鳍条帮它在能见度极低的浑水里精准锁定猎物。",
		"wiki": "馬鮁"},
	# —— 5 神话 ——
	"bahaba": {  # 黄唇鱼
		"desc": "河口里的黄唇鱼，因一只价值连城的鱼鳔而惨遭滥捕，如今已是极度濒危的「水中黄金」。",
		"fact": "黄唇鱼的鱼鳔被炒作成天价「鱼胶」，一只可值数百万，导致它被疯狂捕杀；如今野生个体极其罕见，是国家一级保护动物。",
		"wiki": "黃唇魚"},
	"sawfish": {  # 锯鳐
		"desc": "顶着一柄长满利齿的「锯」的河口巨怪，挥锯横扫击晕鱼群，是濒临灭绝的远古魟类。",
		"fact": "锯鳐的长吻两侧排着锐利的齿状突起，既能像探测器感知猎物的生物电，又能挥砍击伤鱼群；全球所有锯鳐都已濒危。",
		"wiki": "鋸鰩"},
	# —— 0 普通 ——
	"polar_smelt": {  # 北极公鱼
		"desc": "冰层下成群聚集的冷水小鱼，凿开冰洞放下钩，往往一会儿就是一串。",
		"fact": "北极公鱼是冰钓的主角，群居在冰下水层，体内含有抗冻蛋白，能在接近冰点的水里活动。",
		"wiki": "胡瓜魚"},
	"ninespine_stickleback": {  # 九刺鱼
		"desc": "背上立着一排小硬刺的迷你斗士，个头不大脾气不小，护起巢来谁都敢顶。",
		"fact": "九刺鱼的雄鱼会用水草和分泌的黏液筑一个隧道状的巢，跳起「之」字舞引雌鱼入内产卵。",
		"wiki": "九刺魚"},
	"capelin": {  # 毛鳞鱼
		"desc": "北方冷海里成群洄游的小鱼，产卵季整片海滩翻涌着银光，引来鲸鸟争食。",
		"fact": "毛鳞鱼产卵时会成群冲上沙滩，借浪把卵埋进沙里，这一幕「卷滩」是北极食客的年度盛宴。",
		"wiki": "毛鱗魚"},
	"pond_smelt": {  # 西太公鱼
		"desc": "冬日结冰湖面下的小银鱼，是冰钓人最熟悉的伙伴，一口一口咬得勤快。",
		"fact": "西太公鱼寿命通常只有一年，秋生春产后便逝去，却是高山冰湖里最重要的越冬口粮。",
		"wiki": "西太公魚"},
	# —— 1 优良 ——
	"arctic_cisco": {  # 北极白鲑
		"desc": "极地冰湖里成群洄游的白鲑，肉质清甜，是高纬度居民重要的越冬鱼获。",
		"fact": "北极白鲑属鲑科白鲑类，能在接近冰点的水里成群洄游，是北极圈原住民赖以越冬的传统食物。",
		"wiki": "白鮭"},
	"whitefish": {  # 高白鲑
		"desc": "深冷湖水里的银白群鱼，嘴小温吞，靠滤食浮游生物和底栖小虫过活。",
		"fact": "高白鲑生长缓慢却长寿，是寒冷深湖里的中坚鱼类，肉质细嫩，常被引种到高山冷水湖养殖。",
		"wiki": "高白鮭"},
	"sculpin": {  # 杜父鱼
		"desc": "大头宽嘴趴在冷水底的小怪鱼，胸鳍像扇子撑开，伏在石缝里等猎物送上门。",
		"fact": "杜父鱼没有鱼鳔，只能贴着水底活动，宽大的胸鳍帮它在急流石缝间稳住身形。",
		"wiki": "杜父魚"},
	"ruffe": {  # 梅花鲈
