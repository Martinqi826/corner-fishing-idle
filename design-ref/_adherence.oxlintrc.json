{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/game/**",
              "components/primitives/**",
              "components/surfaces/**",
              "playable/**",
              "ui_kits/corner_fishing/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Noto Sans SC|Noto Serif SC))/i]",
        "message": "Font not provided by the design system. Available: Noto Sans SC, Noto Serif SC."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|variant|legible|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, variant, legible, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:text|pill|outline)$/]",
        "message": "<Badge> variant must be one of 'text' | 'pill' | 'outline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|icon|disabled|onClick|className|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, icon, disabled, onClick, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|surface|pad|interactive|locked|onClick|className|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, surface, pad, interactive, locked, onClick, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='surface'] > Literal[value!=/^(?:paper|row|glass)$/]",
        "message": "<Card> surface must be one of 'paper' | 'row' | 'glass'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DexCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|fallbackSrc|name|tier|known|count|maxWeight|collected|giant|perfect|variants|style|key|ref|className|style|children)$/]",
        "message": "<DexCard> doesn't accept that prop. Declared props: src, fallbackSrc, name, tier, known, count, maxWeight, collected, giant, perfect, variants, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FishIcon'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|fallbackSrc|alt|size|tier|variant|frame|dimmed|style|key|ref|className|style|children)$/]",
        "message": "<FishIcon> doesn't accept that prop. Declared props: src, fallbackSrc, alt, size, tier, variant, frame, dimmed, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FishRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|fallbackSrc|name|tier|variant|quality|weight|sizeTag|locked|value|coinIcon|emphasis|onSell|onToggleLock|style|key|ref|className|style|children)$/]",
        "message": "<FishRow> doesn't accept that prop. Declared props: src, fallbackSrc, name, tier, variant, quality, weight, sizeTag, locked, value, coinIcon, emphasis, onSell, onToggleLock, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='HudChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|icon|tone|size|onClick|style|key|ref|className|style|children)$/]",
        "message": "<HudChip> doesn't accept that prop. Declared props: children, icon, tone, size, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='HudLedger'] > JSXAttribute > JSXIdentifier[name!=/^(?:coins|used|capacity|coinIcon|style|key|ref|className|style|children)$/]",
        "message": "<HudLedger> doesn't accept that prop. Declared props: coins, used, capacity, coinIcon, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Panel'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|subtitle|onClose|children|width|style|bodyStyle|key|ref|className|style|children)$/]",
        "message": "<Panel> doesn't accept that prop. Declared props: title, subtitle, onClose, children, width, style, bodyStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|max|showPercent|caption|surface|style|key|ref|className|style|children)$/]",
        "message": "<ProgressBar> doesn't accept that prop. Declared props: value, max, showPercent, caption, surface, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressBar'] > JSXAttribute[name.name='surface'] > Literal[value!=/^(?:glass|paper)$/]",
        "message": "<ProgressBar> surface must be one of 'glass' | 'paper'."
      },
      {
        "selector": "JSXOpeningElement[name.name='RoundButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|size|title|badge|onClick|style|key|ref|className|style|children)$/]",
        "message": "<RoundButton> doesn't accept that prop. Declared props: icon, size, title, badge, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Slider'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|min|max|step|onChange|format|disabled|style|key|ref|className|style|children)$/]",
        "message": "<Slider> doesn't accept that prop. Declared props: label, value, min, max, step, onChange, format, disabled, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SpotCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|desc|got|total|unlocked|current|event|unlockText|onGo|style|key|ref|className|style|children)$/]",
        "message": "<SpotCard> doesn't accept that prop. Declared props: name, desc, got, total, unlocked, current, event, unlockText, onGo, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SummaryStrip'] > JSXAttribute > JSXIdentifier[name!=/^(?:used|capacity|value|coinIcon|capLabel|valueLabel|style|key|ref|className|style|children)$/]",
        "message": "<SummaryStrip> doesn't accept that prop. Declared props: used, capacity, value, coinIcon, capLabel, valueLabel, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:tabs|active|onChange|variant|overflow|onOverflow|style|key|ref|className|style|children)$/]",
        "message": "<TabBar> doesn't accept that prop. Declared props: tabs, active, onChange, variant, overflow, onOverflow, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabBar'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:pill|underline)$/]",
        "message": "<TabBar> variant must be one of 'pill' | 'underline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toggle'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|label|disabled|style|key|ref|className|style|children)$/]",
        "message": "<Toggle> doesn't accept that prop. Declared props: checked, onChange, label, disabled, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
